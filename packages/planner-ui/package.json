{
  "name": "@retiregolden/planner-ui",
  "version": "0.4.5",
  "description": "The RetireGolden planner React UI: plan picker, planner workspace, results/Monte Carlo/optimizer pages, import wizard, Learning Center, and report export — the full planner tree a host app composes inside its own router. Ships TypeScript source and requires a Vite-class bundler.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RetireGolden/RetireGolden.git",
    "directory": "packages/planner-ui"
  },
  "homepage": "https://github.com/RetireGolden/RetireGolden/tree/main/packages/planner-ui#readme",
  "bugs": "https://github.com/RetireGolden/RetireGolden/issues",
  "keywords": [
    "retirement",
    "financial-planning",
    "react",
    "planner",
    "monte-carlo"
  ],
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/report/goldens",
    "LICENSE",
    "README.md"
  ],
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./plan-format": "./src/data/planFormat.ts",
    "./import-provenance": "./src/import/provenance.ts",
    "./report-model": "./src/report/reportModel.ts",
    "./index.css": "./src/index.css",
    "./*": "./src/*.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@retiregolden/engine": "^0.1.6",
    "highs": "^1.14.2",
    "idb": "^8.0.3",
    "recharts": "^3.8.1"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@retiregolden/mcp": "0.5.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.16",
    "vitest": "^4.0.16"
  }
}
