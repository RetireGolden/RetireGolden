{
  /* Type-checks the co-located *.test.ts files (the build config excludes
     them so tests never ship in dist). Run via `npm test`. */
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "tsBuildInfoFile": "./tsconfig.test.tsbuildinfo",
    "noEmit": true,
    "declaration": false
  },
  "include": ["src"],
  "exclude": []
}
