{
  /* Dev/test config — the file editors and Vite's oxc transform discover next
     to the source, so it must cover every src file, tests included. oxc's
     native tsconfig discovery (vite:oxc) refuses to associate a file the
     nearest tsconfig.json excludes and fails with `[TSCONFIG_ERROR] Tsconfig
     not found` on Windows cold-cache vitest runs, so the test exclude lives
     in tsconfig.build.json instead — tests still never ship in dist.
     Deliberately self-contained (no extends) so discovery stays trivial. */
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",

    /* Linting — mirrors the app's strictness */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "strict": true
  },
  "include": ["src"]
}
